{
  "seed": 42,
  "batch_size": 25,
  "output_dir": "experiments/e0/results",
  "dataset": {
    "csv_path": "data/dataset.csv",
    "text_column": "nm_item",
    "label_column": "nm_product",
    "min_samples_per_class": 5
  },
  "samples": {
    "random_size": 1000,
    "stratified_per_class": 3
  },
  "_notas_desenho": [
    "items_per_call definido pela calibracao (config_calibration.json); rode-a primeiro",
    "MaaS nao suporta structured output em nenhum modelo (console 07/2026) -> json-prompt",
    "RQ4 (enum vs free) restrito a provedores com structured output (OpenAI)"
  ],
  "oracles": [
    {
      "provider": "openai",
      "model": "gpt-4o-mini",
      "mode": "enum",
      "items_per_call": 10,
      "samples": [
        "rand",
        "strat"
      ]
    },
    {
      "provider": "openai",
      "model": "gpt-4o",
      "mode": "enum",
      "items_per_call": 10,
      "samples": [
        "rand",
        "strat"
      ]
    },
    {
      "provider": "openai",
      "model": "gpt-4o-mini",
      "mode": "free",
      "items_per_call": 10,
      "samples": [
        "rand"
      ],
      "_nota": "RQ4 (efeito do instrumento) — so em provedores com structured output"
    }
  ]
}