# Copie para .env e preencha. O .env NUNCA é commitado (está no .gitignore).
# Rotacione qualquer chave que tenha sido compartilhada para testes.

# --- Oráculos LLM (E0+) ---
OPENAI_API_KEY=
OPENROUTER_API_KEY=
MAAS_API_KEY=
MAAS_BASE_URL=https://api-ap-southeast-1.modelarts-maas.com/v2
GEMINI_API_KEY=

# --- FlowBuilder API ---
# Vazio => SQLite local (flowbuilder.db). Para Neon, cole a connection string
# (Dashboard Neon -> Connect -> Connection string), ex.:
# DATABASE_URL=postgresql://user:senha@ep-xxxx.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=
# Origem do frontend em dev (Vite)
FLOWBUILDER_CORS=http://localhost:5173
